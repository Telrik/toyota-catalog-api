                          "label": "Europe"
                        },
                        {
                          "value": "JP",
                          "label": "Japan"
                        },
                        {
                          "value": "OTHER",
                          "label": "Other"
                        }
                      ],
                      "filters": [],
                      "items": []
                    }
                  },
                  "years": {
                    "summary": "region=EU",
                    "value": {
                      "selected": {
                        "region": "EU"
                      },
                      "next": "year",
                      "options": [
                        {
                          "value": 2022,
                          "label": "2022"
                        },
                        {
                          "value": 2010,
                          "label": "2010"
                        },
                        {
                          "value": 2006,
                          "label": "2006"
                        },
                        {
                          "value": 1969,
                          "label": "1969"
                        }
                      ],
                      "filters": [],
                      "items": []
                    }
                  },
                  "models": {
                    "summary": "region=EU&year=2006",
                    "value": {
                      "selected": {
                        "region": "EU",
                        "year": 2006
                      },
                      "next": "model",
                      "options": [
                        {
                          "value": "AYGO",
