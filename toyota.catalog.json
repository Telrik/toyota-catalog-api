    "/vehicle": {
      "get": {
        "operationId": "vehicle",
        "summary": "Get catalog categories and diagrams",
        "description": "Call after region, year, model, and modelCode are known. Returns category tabs and diagrams for categoryId, defaulting to 1.",
        "parameters": [
          {
            "name": "region",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "NA",
                "EU",
                "JP",
                "OTHER"
              ]
            },
            "example": "EU"
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 2006
          },
          {
            "name": "model",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "COROLLA"
          },
          {
            "name": "modelCode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "NDE120L-AHDYW"
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "Selected category id. Defaults to 1, Engine / Fuel.",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Catalog categories and diagrams for the selected vehicle/category.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleCatalogResponse"
                },
                "example": {
                  "selected": {
                    "region": "EU",
                    "year": 2006,
                    "model": "COROLLA",
                    "modelCode": "NDE120L-AHDYW",
                    "categoryId": 1
                  },
                  "categories": [
                    {
                      "categoryId": 1,
                      "label": "Engine / Fuel",
                      "groups": ["Engine", "Water pump", "Radiator", "Alternator", "Starter", "Intake", "Exhaust", "Ignition", "Injection"]
                    },
                    {
                      "categoryId": 2,
                      "label": "Powertrain / Chassis",
                      "groups": ["Transmission", "Driveshaft", "Axle", "Wheels", "Brakes", "Steering", "Suspension"]
                    },
                    {
                      "categoryId": 3,
                      "label": "Body",
                      "groups": ["Doors", "Windows", "Bumper", "Fuel tank", "Interior", "Seats", "Handles"]
                    },
                    {
                      "categoryId": 4,
                      "label": "Electrical",
                      "groups": ["Battery", "Air conditioning", "Lights", "Audio", "Airbag", "Mirror"]
                    }
                  ],
                  "diagrams": [
                    {
                      "diagramId": 1101,
                      "name": "Standard Tool",
                      "url": "EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1101.html",
                      "image": "https://api.example.com/images/toyota/engine-fuel-standard-tool.png"
                    },
                    {
                      "diagramId": 1102,
                      "name": "Partial Engine Assembly",
                      "url": "EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1102.html",
                      "image": "https://api.example.com/images/toyota/engine-fuel-partial-engine-assembly.png"
                    },
                    {
                      "diagramId": 1603,
                      "name": "Water Pump",
                      "url": "EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1603.html",
                      "image": "https://api.example.com/images/toyota/engine-fuel-water-pump.png"
                    },
                    {
                      "diagramId": 1604,
                      "name": "Radiator & Water Outlet",
                      "url": "EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1604.html",
                      "image": "https://api.example.com/images/toyota/engine-fuel-radiator-water-outlet.png"
                    },
                    {
                      "diagramId": 1901,
                      "name": "Alternator",
                      "url": "EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1901.html",
                      "image": "https://api.example.com/images/toyota/engine-fuel-alternator.png"
                    },
                    {
                      "diagramId": 1902,
                      "name": "Starter",
                      "url": "EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1902.html",
                      "image": "https://api.example.com/images/toyota/engine-fuel-starter.png"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/compatibility": {
      "get": {
        "operationId": "compatibility",
        "summary": "Find model-code compatibility by part number",
        "description": "Returns the same model-code table shape used by identify and selector for a supplied part number.",
        "parameters": [
          {
            "name": "partNumber",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "9091520004"
          }
        ],
        "responses": {
          "200": {
            "description": "Compatible model-code rows.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompatibilityResponse"
                },
                "example": {
                  "partNumber": "9091520004",
                  "items": [
                    {
                      "region": "EU",
                      "year": "1993",
                      "model": "COROLLA",
                      "modelCode": "CE100L-AWMRSW",
                      "details": [
                        { "key": "frame", "value": "CE100" },
                        { "key": "engine", "value": "2C" },
                        { "key": "body", "value": "SED" }
                      ]
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/diagram": {
      "get": {
        "operationId": "diagram",
        "summary": "Get diagram image and spare parts",
        "description": "Returns diagram image URL plus spare parts and normalized coordinates for locating part numbers on the image.",
        "parameters": [
          {
            "name": "region",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "EU"
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "1993"
          },
          {
            "name": "model",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "COROLLA"
          },
          {
            "name": "modelCode",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "CE100L-AWMRSW"
          },
          {
            "name": "categoryId",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "example": 1
          },
          {
            "name": "diagramId",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "example": 1102
          }
        ],
        "responses": {
          "200": {
            "description": "Diagram with spare parts and image coordinates.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiagramResponse"
                },
                "example": {
                  "selected": {
                    "region": "EU",
                    "year": "1993",
                    "model": "COROLLA",
                    "modelCode": "CE100L-AWMRSW",
                    "categoryId": 1,
                    "diagramId": 1102
                  },
                  "imageUrl": "https://api.example.com/images/toyota/EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1102.png",
                  "spareParts": [
                    {
                      "partNumber": "9091520004",
                      "description": "Filter, Oil",
                      "params": [
                        { "key": "qty", "value": 1 },
                        { "key": "engine", "value": "2C" }
                      ],
                      "coordinates": [
                        { "x": 0.42, "y": 0.36, "width": 0.12, "height": 0.1 }
                      ]
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IdentifyResponse": {
        "type": "object",
        "description": "VIN/frame lookup result. Partial decodes return every possible model-code row in items. Empty items means no rows were found.",
        "required": [
          "vin",
          "items"
        ],
        "properties": {
          "vin": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelCodeRow"
            }
          }
        }
      },
      "SelectorResponse": {
        "type": "object",
        "required": [
          "selected",
          "options",
          "filters",
          "items"
        ],
        "properties": {
          "selected": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "string",
                "integer"
              ]
            }
          },
          "next": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "region",
              "year",
              "model",
              null
            ]
          },
          "options": {
            "type": "array",
            "description": "Main selector options for the next step: regions, years, models, or empty when model-code rows are shown.",
            "items": {
              "$ref": "#/components/schemas/Option"
            }
          },
          "filters": {
            "type": "array",
            "description": "Variable characteristic filter blocks shown after region, year, and model are selected.",
            "items": {
              "$ref": "#/components/schemas/Filter"
            }
          },
          "items": {
            "type": "array",
            "description": "Matching model-code rows.",
            "items": {
              "$ref": "#/components/schemas/ModelCodeRow"
            }
          }
        }
      },
      "Option": {
        "type": "object",
        "required": [
          "value",
          "label"
        ],
        "properties": {
          "value": {
            "type": [
              "string",
              "integer"
            ]
          },
          "label": {
            "type": "string"
          },
          "hint": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "Filter": {
        "type": "object",
        "required": [
          "code",
          "label",
          "options"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Option"
            }
          }
        }
      },
      "VehicleCatalogResponse": {
        "type": "object",
        "required": [
          "selected",
          "categories",
          "diagrams"
        ],
        "properties": {
          "selected": {
            "type": "object",
            "required": [
              "region",
              "year",
              "model",
              "modelCode",
              "categoryId"
            ],
            "properties": {
              "region": {
                "type": "string"
              },
              "year": {
                "type": "integer"
              },
              "model": {
                "type": "string"
              },
              "modelCode": {
                "type": "string"
              },
              "categoryId": {
                "type": "integer"
              }
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          },
          "diagrams": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Diagram"
            }
          }
        }
      },
      "Category": {
        "type": "object",
        "required": [
          "categoryId",
          "label",
          "groups"
        ],
        "properties": {
          "categoryId": {
            "type": "integer"
          },
          "label": {
            "type": "string"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Diagram": {
        "type": "object",
        "required": [
          "diagramId",
          "name",
          "url",
          "image"
        ],
        "properties": {
          "diagramId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "description": "Full diagram page URL/path, for example EU.1993.TOYOTA_COROLLA.CE100L-AWMRSW.1102.html."
          },
          "image": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "ModelCodeRow": {
        "type": "object",
        "properties": {
          "region": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "model": {
